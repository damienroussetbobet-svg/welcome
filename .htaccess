# ── Compression gzip ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE font/woff2 font/woff image/svg+xml
</IfModule>

# ── Cache navigateur ──────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # JS/CSS/polices : 1 an (assets versionnés ou stables)
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript        "access plus 1 year"
  ExpiresByType text/css               "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
  ExpiresByType font/woff              "access plus 1 year"

  # Images
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/gif  "access plus 1 month"

  # HTML/PHP : pas de cache (contenu dynamique)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── En-têtes Cache-Control ────────────────────────────────────────
<IfModule mod_headers.c>
  # Assets statiques : cache long + immutable
  <FilesMatch "\.(js|css|woff2|woff|png|jpg|jpeg|webp|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # PHP : jamais en cache
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # Sécurité
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Uploads : interdit de lister le répertoire ────────────────────
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>
